step 1:

/api/v1/dobepayment/donate
{
  "name": "Lokesh V",
  "email": "lokeshv5844@gmail.com",
  "phone": "9597670814",
  "amount": 1000
}

step 2: integrate with frontend
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  var options = {
    "key": "YOUR_KEY_ID", // Replace with your Razorpay key_id
    "amount": 10000, // Amount in paise
    "currency": "INR",
    "order_id": "order_SeB0Hk0INK2ofU", // Order ID from your backend
    "handler": function (response){
        // These are the values you need!
        console.log(response.razorpay_payment_id);   // <-- payment_id
        console.log(response.razorpay_order_id);     // <-- order_id
        console.log(response.razorpay_signature);    // <-- signature

        // Send these to your backend /api/v1/dobepayment/verify endpoint
        fetch('/api/v1/dobepayment/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            order_id: response.razorpay_order_id,
            payment_id: response.razorpay_payment_id,
            signature: response.razorpay_signature
          })
        })
        .then(res => res.json())
        .then(data => console.log(data));
    }
  };
  var rzp1 = new Razorpay(options);
  rzp1.open();
</script>


